    "motion": "^12.23.24",
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.3.1",
    "typescript": "^5.8.2"
  }
}
